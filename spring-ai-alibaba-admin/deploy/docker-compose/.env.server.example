# Timezone
TZ=Asia/Shanghai

# Data directory for container volumes
DATA_HOME=./data

# Images
BACKEND_IMAGE=spring-ai-admin-backend
FRONTEND_IMAGE=spring-ai-admin-frontend
IMAGE_TAG=latest

# Exposed ports
BACKEND_PORT=28080
FRONTEND_PORT=80
ES_HTTP_PORT=9200
ES_TRANSPORT_PORT=9300
KIBANA_PORT=5601
NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT_10909=10909
ROCKETMQ_BROKER_PORT_10911=10911
ROCKETMQ_BROKER_PORT_10912=10912
ROCKETMQ_PROXY_PORT=18080
ROCKETMQ_PROXY_ADMIN_PORT=18081
OTLP_PORT=4318

# MySQL on server host (NOT in container)
# If backend runs in container and DB runs on same host, default host should be host.docker.internal
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=admin
MYSQL_USER=admin
MYSQL_PASSWORD=admin

# Redis on server host (NOT in container)
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=123456

